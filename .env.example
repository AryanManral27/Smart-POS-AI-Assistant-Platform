# Optional: set OpenRouter key only if you want live LLM output.
# Keep blank to run fully in rule-based/fallback mode (no API key needed).
OPENROUTER_API_KEY="your_api_key_here"
# Optional OpenRouter settings (used only when OPENROUTER_API_KEY is provided)
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
